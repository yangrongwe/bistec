<block wx:if="{{hasPermission}}"><view class="data-v-57280228"><view hidden="{{!(isOk)}}" class="container data-v-57280228"><image class="all-back data-v-57280228" src="{{back}}" mode></image><bluetooth-content vue-id="8dd740cc-1" launch="{{modalStatus}}" isOk="{{isOk}}" class="data-v-57280228" bind:__l="__l"></bluetooth-content><view-tabbar vue-id="8dd740cc-2" current="{{current}}" data-event-opts="{{[['^changeToSport',[['changeToSport']]]]}}" bind:changeToSport="__e" class="data-v-57280228" bind:__l="__l"></view-tabbar></view></view></block><block wx:else><view style="text-align:center;display:flex;justify-content:center;background-color:white;height:100vh;" class="data-v-57280228"><view style="width:80%;margin-top:500rpx;" class="data-v-57280228"><block wx:if="{{loading}}"><view class="data-v-57280228"><view class="data-v-57280228"><text class="data-v-57280228">{{authErr?"权限验证失败，请联系客服":"正在验证是否授权，请稍等..."}}</text></view></view></block><block wx:else><view class="data-v-57280228"><view class="data-v-57280228"><text class="data-v-57280228">当前用户未授权，请绑定授权码</text></view><view style="margin-top:24rpx;" class="data-v-57280228"><uni-easyinput bind:input="__e" vue-id="8dd740cc-3" type="textarea" value="{{authCode}}" data-event-opts="{{[['^input',[['__set_model',['','authCode','$event',[]]]]]]}}" class="data-v-57280228" bind:__l="__l"></uni-easyinput></view><view style="margin-top:24rpx;" class="data-v-57280228"><button type="primary" plain="true" data-event-opts="{{[['tap',[['bindAuthCode',['$event']]]]]}}" bindtap="__e" class="data-v-57280228">请求授权</button></view></view></block></view></view></block>